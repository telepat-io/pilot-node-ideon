# Copy to .env and fill in. Used by compose.yaml (production) at deploy time.
# The air-gapped smoke test (compose.smoke.yaml) needs only IDEON_MCP_API_KEY.

# ── Ideon MCP (required) ──────────────────────────────────────────────────────
# Bearer key the Ideon MCP HTTP server requires and our wrapper sends. Any value
# works for a dry-run; a real Ideon deployment defines its own key.
IDEON_MCP_API_KEY=changeme

# ── Real article generation ───────────────────────────────────────────────────
# Dry-run writes a placeholder article and contacts NO external provider. For real
# content set IDEON_DRY_RUN=false and provide the Ideon provider key(s) below.
IDEON_DRY_RUN=false
OPENROUTER_API_KEY=
# REPLICATE_API_TOKEN=        # only if you raise maxImages for real images

# ── Pilot overlay endpoints ───────────────────────────────────────────────────
# Where the provider daemon registers so buyers can reach the node. Defaults to
# the real Pilot network. Point these at a self-hosted rendezvous for a private
# deployment. Confirm the current Pilot registry/beacon with the Pilot team.
PILOT_REGISTRY=34.71.57.205:9000
PILOT_BEACON=34.71.57.205:9001

# ── Optional ──────────────────────────────────────────────────────────────────
# PILOT_HOSTNAME=ideon-provider
# LOG_LEVEL=info
